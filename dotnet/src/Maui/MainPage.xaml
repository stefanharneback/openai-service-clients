<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenAiServiceClients.Maui.MainPage"
             Title="OpenAI Service Clients">
    <ScrollView>
    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="OpenAI Service Clients"
               FontSize="28"
               FontAttributes="Bold" />
        <Label Text="MAUI starter client for gateway full-chain testing." />

        <Label Text="Client API key" />
        <Entry x:Name="ApiKeyEntry" IsPassword="True" Placeholder="sk-client-..." />

        <Label Text="Model" />
        <Picker x:Name="ModelPicker" Title="Loading models..." />

        <Label Text="Input" />
        <Editor x:Name="InputEditor" HeightRequest="120" Text="Summarize the value of API gateways in three bullets." />

        <Button Text="Check /health" Clicked="OnHealthClicked" />
        <Button Text="Send /v1/llm" Clicked="OnLlmClicked" />
        <Button Text="Stream /v1/llm" Clicked="OnLlmStreamClicked" />
    <Label x:Name="UsageStatsLabel" TextColor="Gray" FontSize="12" IsVisible="False" />


        <Label Text="Whisper" FontSize="20" FontAttributes="Bold" Margin="0,12,0,0" />
        <Label Text="Whisper model" />
        <Entry x:Name="WhisperModelEntry" Text="whisper-1" />

        <Button Text="Pick Audio &amp; Transcribe /v1/whisper" Clicked="OnWhisperClicked" />

        <Label Text="Usage" FontSize="20" FontAttributes="Bold" Margin="0,12,0,0" />
        <Label Text="Limit" />
        <Entry x:Name="UsageLimitEntry" Text="20" Keyboard="Numeric" />
        <Label Text="Offset" />
        <Entry x:Name="UsageOffsetEntry" Text="0" Keyboard="Numeric" />
        <Button Text="Get /v1/usage" Clicked="OnUsageClicked" />

        <Label Text="Admin Usage" FontSize="20" FontAttributes="Bold" Margin="0,12,0,0" />
        <Label Text="Admin key" />
        <Entry x:Name="AdminKeyEntry" IsPassword="True" Placeholder="admin-secret..." />
        <Label Text="Limit" />
        <Entry x:Name="AdminLimitEntry" Text="20" Keyboard="Numeric" />
        <Label Text="Offset" />
        <Entry x:Name="AdminOffsetEntry" Text="0" Keyboard="Numeric" />
        <Button Text="Get /v1/admin/usage" Clicked="OnAdminUsageClicked" />

        <Label Text="Result" FontAttributes="Bold" />
        <Editor x:Name="ResultEditor" AutoSize="TextChanges" IsReadOnly="True" HeightRequest="220" />
    </VerticalStackLayout>
    </ScrollView>
</ContentPage>
